# Credenciais FTP Hostinger — NÃO commitar (está no .gitignore)
# Copie este arquivo para `.env.deploy` e preencha.

# Host FTP (hPanel → Arquivos → Contas FTP)
FTP_SERVER=ftp.guiachapadaveadeiros.com

# Usuário e senha da conta FTP
FTP_USERNAME=
FTP_PASSWORD=

# Porta (21) + FTPS explícito (recomendado na Hostinger)
FTP_PORT=21
FTP_SECURE=true

# Pasta remota. Na maioria das contas Hostinger o login já cai em public_html → use ./
# Se o FTP abrir na home do usuário, use: public_html/
FTP_REMOTE_DIR=./

# 1 = log detalhado do protocolo
FTP_VERBOSE=0

# Opcional: no fim de todo `npm run build`, enviar automaticamente
# GCV_DEPLOY_FTP=1
