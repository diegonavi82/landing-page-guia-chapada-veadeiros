# Guia Chapada Veadeiros — .htaccess raiz

Options -Indexes

# Proteger arquivos sensíveis
<FilesMatch "^(\.env|config\.local\.php|composer\.json|composer\.lock)$">
  Order allow,deny
  Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Bloquear acesso direto a vendor
  RewriteRule ^api/vendor/ - [F,L]

  # URLs sem extensão → .html (ex: /login → /login.html)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ /$1.html [L]

  # Diretórios com index.html (ex: /dashboard/ → /dashboard/index.html)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]
</IfModule>

# Headers de segurança
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "1; mode=block"
</IfModule>
