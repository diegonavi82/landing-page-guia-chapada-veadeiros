# Copie para .env e ajuste. Variáveis são lidas pelo gerador de HTML (npm run build).

# Para o formulário de contato no browser apontar para a API (POST JSON), defina também

# a URL completa se for diferente do SITE_ORIGIN padrão (ex.: testar API local).



# URL canônica do site (hreflang, meta og:url, JSON-LD)

SITE_ORIGIN=https://www.guiachapadaveadeiros.com



# Scripts nas páginas: `npm run build` → `/assets/js/…?v=(versão)` (produção HTTPS na raíz).

# Para abrir .html pelo disco (`file://`): `npm run build:file` ou `GCV_RELATIVE_JS=1` → caminhos relativos.



# Onde o formulário de /contato envia o POST (por omissão: SITE_ORIGIN + /api/contact)

# Exemplo dev: CONTACT_POST_URL=http://localhost:3333/api/contact

# CONTACT_POST_URL=



# WhatsApp — links wa.me no HTML

WHATSAPP_PHONE_E164=5562982506891



# E-mail exibido na página e em mailto:

CONTACT_EMAIL=contato@guiachapadaveadeiros.com



# Web3Forms (https://web3forms.com) — cole a Access Key; com ela definida o /contato usa e-mail via Web3Forms

# e ignora CONTACT_POST_URL nesse fluxo (o JS envia POST para api.web3forms.com).

# WEB3FORMS_ACCESS_KEY=



# Ícone nos resultados do Google — arquivo em /assets/img/ (ex.: PNG ~192 px, ICO ou SVG)

# FAVICON_REL=imagens/favicon.png



# --- Instagram na home (100% gratuito, sem SnapWidget) ---

# Opção A — API oficial Meta (grátis): conta Profissional + Página do Facebook ligada.

#   1) App em https://developers.facebook.com/docs/instagram-api/getting-started

#   2) Token com permissão instagram_basic (e instagram_manage_insights se pedir)

#   3) ID da conta Instagram Business (não é o @usuario):

# INSTAGRAM_ACCESS_TOKEN=

# INSTAGRAM_BUSINESS_ACCOUNT_ID=

#   Atualizar fotos: npm run sync:instagram  (grava tools/instagram-feed.json + assets/img/instagram/)

#   Depois: npm run build

#   Opcional — buscar na API em todo build: INSTAGRAM_FETCH_ON_BUILD=1

#   Quantidade de posts (padrão 9; home manual costuma usar 8 em grade 4×2): INSTAGRAM_FEED_LIMIT=9

#

# Opção B — manual (sem API): copie tools/instagram-feed.example.json → tools/instagram-feed.json,

#   coloque imagens em assets/img/instagram/ e liste permalink + image + alt. Rode npm run build.



# --- MySQL (Hostinger) — pasta api/ no FTP, não no npm run build do HTML ---

# Credenciais ficam em api/config.local.php (copie de api/config.example.php).

# Teste após upload: https://www.guiachapadaveadeiros.com/api/health.php

# O formulário /contato grava no banco via POST /api/contact (em paralelo ao Web3Forms, se ativo).


