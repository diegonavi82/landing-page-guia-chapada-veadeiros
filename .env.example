# Copie para .env e ajuste. Variáveis são lidas pelo gerador de HTML (npm run build).
# Para o formulário de contato no browser apontar para a API (POST JSON), defina também
# a URL completa se for diferente do SITE_ORIGIN padrão (ex.: testar API local).

# URL canônica do site (hreflang, meta og:url, JSON-LD)
SITE_ORIGIN=https://www.guiachapadaveadeiros.com

# Scripts nas páginas: `npm run build` → `/assets/js/…?v=(versão)` (produção HTTPS na raíz).
# Para abrir .html pelo disco (`file://`): `npm run build:file` ou `GCV_RELATIVE_JS=1` → caminhos relativos.

# Onde o formulário de /contato envia o POST (por omissão: SITE_ORIGIN + /api/contact)
# Exemplo dev: CONTACT_POST_URL=http://localhost:3333/api/contact
# CONTACT_POST_URL=

# WhatsApp — links wa.me no HTML
WHATSAPP_PHONE_E164=5562982506891

# E-mail exibido na página e em mailto:
CONTACT_EMAIL=contato@guiachapadaveadeiros.com

# Web3Forms (https://web3forms.com) — cole a Access Key; com ela definida o /contato usa e-mail via Web3Forms
# e ignora CONTACT_POST_URL nesse fluxo (o JS envia POST para api.web3forms.com).
# WEB3FORMS_ACCESS_KEY=

# Ícone nos resultados do Google — arquivo em /assets/img/ (ex.: PNG ~192 px, ICO ou SVG)
# FAVICON_REL=imagens/favicon.png

# --- Não aplicam a este projeto estático ---
# DATABASE_URL=
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
