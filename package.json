{
  "name": "guia-chapada-landing-estatica",
  "private": true,
  "version": "1.0.38",
  "description": "Site 100% estático (HTML/CSS/JS) — sem API, sem MySQL.",
  "scripts": {
    "dev": "node tools/mock-server.mjs",
    "dev:admin": "node tools/mock-server.mjs admin",
    "dev:guide": "node tools/mock-server.mjs guide",
    "dev:client": "node tools/mock-server.mjs client",
    "sync:media": "node tools/sync-media.mjs",
    "images:webp": "node tools/to-webp.mjs",
    "sync:instagram": "node tools/sync-instagram.mjs",
    "fetch:instagram": "node tools/fetch-instagram-images.mjs",
    "favicons": "node tools/generate-favicons.mjs",
    "build": "node tools/generate-favicons.mjs && node tools/build-site.mjs",
    "vendor:qrcode": "esbuild node_modules/qrcode/lib/browser.js --bundle --format=iife --global-name=QRCode --outfile=assets/js/qrcode.min.js --minify",
    "preview": "npx --yes serve . -l 3000",
    "preview:prod": "npx --yes serve Build_prod -l 3000",
    "build:file": "node tools/run-build-relative-js.mjs",
    "ftp": "node tools/open-ftp.mjs",
    "setup": "npm run sync:media && npm run images:webp && npm run build"
  },
  "devDependencies": {
    "linkedom": "^0.18.12",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  }
}
